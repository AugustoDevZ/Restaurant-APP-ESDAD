<Page x:Class="Zrutas.UI.Views.Frames.Setting"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Zrutas.UI.Views.Frames"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="1020"
      Title="Setting">

    <Grid>


        <!--Settin 2-->


        <Border Grid.Column="0"
            Background="#FAFAFA"
            CornerRadius="20"
            Margin="30,73,486,359"
            Effect="{DynamicResource ShadowStyle2}"
            Padding="18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="4*"/>
                    <RowDefinition Height="9*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="161*"/>
                    <ColumnDefinition Width="73*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnImage" 
                     Content="Administrar Roles" 
                     Height="35"
                     Foreground="White"
                     Background="#EA6233"
                     Template="{DynamicResource ButtonTwo}"
                     FontSize="14.5"
                     FontWeight="SemiBold" Click="btnRoles_Click" Margin="0,20,0,25" Grid.Column="1" Grid.RowSpan="2"/>
                <Label 
                    x:Name="lblTemeSettingLore1_Copiar" 
                    Content="Administra los permisos de las opciones de la&#xA;app mediante roles personalizables." 
                    AutomationProperties.Name="" 
                    AutomationProperties.HelpText="" 
                    Foreground="{DynamicResource FontColor}" 
                    FontSize="15" 
                    FontWeight="Light" 
                    IsEnabled="False" HorizontalContentAlignment="Left" Margin="0" Grid.Row="1"/>
                <Label 
                    x:Name="lblTemeSetting_Copiar" 
                    Content="Administrar Permisos App" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center" 
                    AutomationProperties.Name="" 
                    AutomationProperties.HelpText="" 
                    Foreground="{DynamicResource FontColor}" 
                    FontSize="15" 
                    FontWeight="Bold" 
                    Height="30" 
                    Width="322" 
                    IsEnabled="False" HorizontalContentAlignment="Left" Margin="0" />


            </Grid>

        </Border>
        <Border Grid.Column="0"
            Background="#FAFAFA"
            CornerRadius="20"
            Margin="551,73,10,20"
            Effect="{DynamicResource ShadowStyle2}"
            Padding="18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40*"/>
                    <RowDefinition Height="57*"/>
                    <RowDefinition Height="76*"/>
                    <RowDefinition Height="49*"/>
                    <RowDefinition Height="82*"/>
                    <RowDefinition Height="46*"/>
                    <RowDefinition Height="71*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnImageCambiar" 
                    Content="Cambiar Imagen"
                    Foreground="White"
                    Background="#EA6233"
                    Template="{DynamicResource ButtonTwo}"
                    FontSize="14.5"
                    FontWeight="SemiBold" Grid.Row="3" Margin="239,3,32,2" Click="btnImageCambiar_Click"/>
                <TextBlock 
                    x:Name="lblTemeSettingLore1_Copiar2" 
                    AutomationProperties.Name="" 
                    AutomationProperties.HelpText="" 
                    Foreground="{DynamicResource FontColor}" 
                    FontSize="15" 
                    FontWeight="Light" 
                    IsEnabled="False" Grid.Row="1"><Run Text="Tu cuenta puede tener varios perfiles"/><Run Text=" "/><Run Text="internamente para "/><Run Language="es-pe" Text="a"/><Run Text="dministrar "/><LineBreak/><Run Text="los permisos de uso."/></TextBlock>
                <Label 
                    x:Name="lblTemeSetting_Copiar1" 
                    Content="Mi perfil" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Center" 
                    AutomationProperties.Name="" 
                    AutomationProperties.HelpText="" 
                    Foreground="{DynamicResource FontColor}" 
                    FontSize="15" 
                    FontWeight="Bold" 
                    Height="40" 
                    Width="291" 
                    IsEnabled="False" HorizontalContentAlignment="Left" />
                <Image x:Name="imgPerfil" Source="/Resources/lnYep.png" Stretch="Fill" Margin="2,0,221,7" Grid.Row="2" Grid.RowSpan="3"/>
                <Label 
                    x:Name="lblTemeSetting_Copiar3" 
                    Content="Mis roles" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Center" 
                    AutomationProperties.Name="" 
                    AutomationProperties.HelpText="" 
                    Foreground="{DynamicResource FontColor}" 
                    FontSize="15" 
                    FontWeight="Bold" 
                    Height="40" 
                    Width="291" 
                    IsEnabled="False" HorizontalContentAlignment="Left" Grid.Row="5" />


            </Grid>

        </Border>
        <Grid Margin="564,431,22,38">
            <Grid.RowDefinitions>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="223*"/>
                <ColumnDefinition Width="211*"/>
            </Grid.ColumnDefinitions>
            <TextBlock
                x:Name="lblProducto3_Copiar1" 
                Text="Rol actual" 
                AutomationProperties.Name="" 
                AutomationProperties.HelpText="" 
                Foreground="Black" 
                TextAlignment="Center"
                
                FontSize="12" 
                FontWeight="Light" 
                IsEnabled="False" FontFamily="Tahoma" Margin="0,0,7,56"/>
            <TextBlock
                x:Name="lblProducto3_Copiar" 
                Text="Cambiar Rol" 
                AutomationProperties.Name="" 
                AutomationProperties.HelpText="" 
                Foreground="Black" 
                TextAlignment="Center"
                
                FontSize="12" 
                FontWeight="Light" 
                IsEnabled="False" FontFamily="Tahoma" Margin="220,0,-2,56" Grid.ColumnSpan="2"/>
            <TextBlock
                x:Name="tbxRolActual" 
                Text="[🛡️ Admin ]" 
                AutomationProperties.Name="" 
                AutomationProperties.HelpText="" 
                Foreground="Black" 
                TextAlignment="Center"
                
                FontSize="12" 
                FontWeight="Light" 
                IsEnabled="False" FontFamily="Tahoma" Margin="1,33,6,23"/>

        </Grid>
        <Border Margin="780,456,22,64" Background="White"
            BorderBrush="#E8440A" BorderThickness="0,0,0,2"
            CornerRadius="12">

            <ComboBox x:Name="cbxCambiarRol"
                      PreviewMouseDown="PreviewMouseDown_Click"
                       SelectionChanged="cbxCambiarRol_SelectionChanged"
                Height="23"
                BorderThickness="0"
                Style="{DynamicResource TransparentComboBox}" Margin="0,2,10,2"
                            >

            </ComboBox>

        </Border>
        <Label 
            x:Name="lblTitleGlobal" 
            Content="Configuración" 
            HorizontalAlignment="Left" 
            Margin="23,0,0,0" 
            VerticalAlignment="Top" 
            AutomationProperties.Name="" 
            AutomationProperties.HelpText="" 
            Foreground="{DynamicResource FontColor}" 
            FontSize="25" 
            FontWeight="Bold" Height="43" Width="131"/>

    </Grid>
</Page>
