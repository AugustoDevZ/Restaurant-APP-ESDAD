<Page x:Class="Zrutas.UI.Views.Content.Inventory"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Zrutas.UI.Views.Content"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="1020"
      Title="Inventory">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="59"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="1" Margin="30,24,30,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>


            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                        Text="AGREGAR PLATO"
                        FontSize="13" FontWeight="Bold"
                        Foreground="{DynamicResource FontColor}"
                        Margin="0,0,0,16"/>

                <TextBlock Grid.Row="1"
                        Text="Nombre del plato"
                        FontSize="11"
                        Foreground="#888888"
                        Margin="0,0,0,4"/>

                <Border 
                    CornerRadius="15" 
                    Grid.Row="2"
                    BorderThickness="2" 
                    Background="Aqua" 
                    SnapsToDevicePixels="True"
                    ClipToBounds="True"
                    Margin="0,0,0,6">
                    <Border.Clip>
                        <RectangleGeometry RadiusX="15" RadiusY="20" Rect="2,0,316,45"/>
                    </Border.Clip>

                    <TextBox x:Name="TxtNombre"
                        
                        Padding="12,10"
                        FontSize="14"
                        Foreground="Gray"
                        Background="#F5F5F5"
                        BorderBrush="#E8440A"
                        BorderThickness="0,0,0,2"
                        Tag="Ej: Lomo Saltado"
                        Text="Ej: Lomo Saltado"
                        GotFocus="TextBox_GotFocus"                            
                        LostFocus="TextBox_LostFocus"
                        Margin="0,0,0,0"/>
                </Border>

                <TextBlock Grid.Row="3"
                    Text="Descripción"
                    FontSize="11"
                    Foreground="#888888"
                    Margin="0,0,0,4"/>

                <Border 
                     CornerRadius="15" 
                     Grid.Row="4"
                     BorderThickness="2" 
                     Background="Aqua" 
                     SnapsToDevicePixels="True"
                     ClipToBounds="True"
                     Margin="0,0,0,16">
                    <Border.Clip>
                        <RectangleGeometry RadiusX="15" RadiusY="20" Rect="2,0,316,45"/>
                    </Border.Clip>
                    <TextBox x:Name="TxtDescripcion"
                      
                      Padding="12,10"
                      FontSize="14"
                      Foreground="Gray"
                      Background="#F5F5F5"
                      BorderBrush="#E8440A"
                      BorderThickness="0,0,0,2"
                      Tag="Ej: Con papas y arroz"
                      Text="Ej: Con papas y arroz"
                      GotFocus="TextBox_GotFocus"
                      LostFocus="TextBox_LostFocus"
                      Margin="0,0,0,0"/>
                </Border>
                <TextBlock Grid.Row="5"
                        Text="Precio (S/.)"
                        FontSize="11"
                        Foreground="#888888"
                        Margin="0,0,0,4"/>
                <Border 
                     CornerRadius="15" 
                     Grid.Row="6"
                     BorderThickness="2" 
      
                     SnapsToDevicePixels="True"
                     ClipToBounds="True"
                     Margin="0,0,0,24">
                    <Border.Clip>
                        <RectangleGeometry RadiusX="15" RadiusY="20" Rect="2,0,316,45"/>
                    </Border.Clip>
                    <TextBox x:Name="TxtPrecio"
                        Padding="12,10"
                        FontSize="14"
                        Foreground="Gray"
                        Background="#F5F5F5"
                        BorderBrush="#E8440A"
                        BorderThickness="0,0,0,2"
                        Tag="Ej: 25.00"
                        Text="Ej: 25.00"
                        GotFocus="TextBox_GotFocus"
                        LostFocus="TextBox_LostFocus"
                        Margin="0,0,0,0"/>
                </Border>


                <Button x:Name="btnAgregarProductos" 
                     Content="+ AGREGAR PLATO"
                     Click="BtnAgregar_Click"
                     Padding="0,16"
                     FontSize="13"
                     Height="40"
                     Grid.Row="7" 
                     FontWeight="Bold"
                     Background="#E8440A"
                     Foreground="White"
                     Margin="0,0,0,12"
                     Template="{DynamicResource ButtonTwo}"
                     BorderThickness="0"
                     />
                <Button x:Name="btnEliminarProductos" 
                     Content="— ELIMINAR SELECCIONADO"
                     Click="BtnEliminar_Click"
                     Padding="0,14"
                     FontSize="13"
                     Height="50"
                     FontWeight="Bold"
                     Template="{DynamicResource ButtonOne}"
                     Background="White"
                     Foreground="#E8440A"
                     Grid.Row="8" 
                     BorderBrush="#E8440A"
                     Cursor="Hand"/>
                <Button x:Name="btnEditarPRoducto" 
                    Content="+ AGREGAR PLATO"
                    Padding="0,16"
                    FontSize="13"
                    Height="40"
                    Grid.Row="8" 
                    FontWeight="Bold"
                    Background="#E8440A"
                    Foreground="White"
                    Margin="0,55,0,-45"
                    Template="{DynamicResource ButtonTwo}"
                    BorderThickness="0"
                     />
            </Grid>

            <Rectangle Grid.Column="1"
                    Width="1"
                    Fill="#DDDDDD"
                    HorizontalAlignment="Center"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                        Text="PLATOS DISPONIBLES"
                        FontSize="13" FontWeight="Bold"
                        Foreground="{DynamicResource FontColor}"
                        Margin="0,0,0,16"/>

                <ListBox x:Name="LstPlatos"
                      Grid.Row="1"
                      Background="#F9F9F9"
                      BorderBrush="#EEEEEE"
                      BorderThickness="1"                         
                      Padding="8">

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="16,12"/>
                            <Setter Property="Margin" Value="0,4"/>
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="#222222"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#E8440A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <TextBlock Grid.Row="2"
                        x:Name="TxtTotal"
                        FontSize="12"
                        Foreground="#AAAAAA"
                        Margin="0,12,0,0"/>
            </Grid>
        </Grid>
        <Label 
            x:Name="lblTitleGlobal" 
            Content="Inventario" 
            HorizontalAlignment="Left" 
            Margin="23,0,0,0" 
            VerticalAlignment="Top" 
            AutomationProperties.Name="" 
            AutomationProperties.HelpText="" 
            Foreground="{DynamicResource FontColor}" 
            FontSize="25" 
            FontWeight="Bold" Height="43" Width="131"/>
    </Grid>
</Page>
